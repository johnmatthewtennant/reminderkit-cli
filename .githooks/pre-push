#!/bin/bash
# Pre-push hook: verify generator output matches committed reminderkit-generated.m
# Fails if `make generate` would change reminderkit-generated.m, indicating the
# generator and source are out of sync.

set -e

echo "pre-push: checking generator sync..."

# Run the generator
make generate >/dev/null 2>&1

# Check if reminderkit-generated.m has uncommitted changes
if ! git diff --quiet reminderkit-generated.m; then
    echo "ERROR: reminderkit-generated.m has uncommitted changes after 'make generate'."
    echo "The generator (generate-cli.py) and reminderkit-generated.m are out of sync."
    echo ""
    echo "Either:"
    echo "  1. Run 'make generate' and commit the result, or"
    echo "  2. Update generate-cli.py to match manual changes in reminderkit-generated.m"
    exit 1
fi

echo "pre-push: generator sync OK"
